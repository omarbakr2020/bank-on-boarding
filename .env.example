# ─── BankOnboard Environment Variables ───────────────────────
# Copy this to .env and fill in your values
# NEVER commit .env to source control

# ─── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ─── Auth ────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change-me-generate-with-openssl-rand-hex-64
JWT_ISSUER=https://bankonboard.io
JWT_AUDIENCE=bankonboard-api
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# ─── Database ────────────────────────────────────────────────
POSTGRES_USER=bankonboard
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=bankonboard
DATABASE_URL=postgresql://bankonboard:change-me-strong-password@postgres:5432/bankonboard

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Service URLs (internal docker network) ──────────────────
PARTY_SERVICE_URL=http://party-service:8000
AI_SERVICE_URL=http://ai-service:8001
GATEWAY_URL=http://localhost:3000

# ─── CORS ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:4200

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Service-to-Service Auth ─────────────────────────────────
# Generate with: openssl rand -hex 32
SERVICE_API_KEY=change-me-service-to-service-secret
